Options -Indexes
Options -MultiViews
Options +FollowSymLinks

# Deny access to config and includes
<FilesMatch "^(config|includes)">
    Require all denied
</FilesMatch>

# Protect sensitive files
<FilesMatch "\.(sql|md|env|log|sh|bak)$">
    Require all denied
</FilesMatch>

RewriteEngine On
RewriteBase /

# Redirect to HTTPS if available (comment out on localhost)
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Block access to hidden files (.git, .env, etc.)
RewriteRule (^|/)\.(?!well-known) - [F]

# Route /admin to admin/index.php when no trailing file
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^admin/?$ admin/index.php [L]

# Security headers
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set X-XSS-Protection "1; mode=block"
</IfModule>

# Gzip compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript text/plain
</IfModule>

# Browser caching for static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css                  "access plus 1 week"
    ExpiresByType application/javascript    "access plus 1 week"
    ExpiresByType image/jpeg                "access plus 1 month"
    ExpiresByType image/png                 "access plus 1 month"
    ExpiresByType image/webp                "access plus 1 month"
</IfModule>
